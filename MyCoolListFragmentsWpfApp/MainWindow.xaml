<Window x:Class="MyCoolListFragmentsWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyCoolListFragmentsWpfApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" PreviewTextInput="NumberValidationTextBox">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <Label Content="Введите ширину:"/>
            <TextBox x:Name="widthFragmentTB"/>
            <Label Content="Введите высоту:"/>
            <TextBox x:Name="heightFragmentTB"/>
            <Label Content="Введите количество:"/>
            <TextBox x:Name="countFragmentTB"/>
            <Button x:Name="generationListFragments" Content="Сгенерировать" Height="25" Click="generationListFragments_Click"/>
            <DataGrid x:Name="FragmentsDG" Margin="0, 5, 0, 15" MaxHeight="230" VerticalScrollBarVisibility="Auto" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ Фрагмента" Binding="{Binding Number}"/>
                    <DataGridTextColumn Header="X" Binding="{Binding X}"/>
                    <DataGridTextColumn Header="Y" Binding="{Binding Y}"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="MainItemsControl" ItemsSource="{Binding Fragment}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="180" Height="180" BorderBrush="Black" BorderThickness="1">
                            <Grid>
                                <Image Source="{Binding Image}" Stretch="UniformToFill"/>

                                <Border Background="#AAFFFFFF" VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <Label Content="{Binding Number}" Margin="5" Background="Transparent"/>
                                        <Label Content="{Binding X}" Margin="5" Background="Transparent"/>
                                        <Label Content="{Binding Y}" Margin="5" Background="Transparent"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
